# ── Live trading instance ──────────────────────────────────────────────
# Copy to `.env.live` (gitignored) and fill in real broker credentials.
# Run with:
#   docker compose --env-file .env.live -p hermes-live up -d --build
#
# The watcher dashboard will be at http://localhost:8082
#
# IMPORTANT: this instance places real orders against real money.
# Treat every change to it as a production deploy — see SETUP_GUIDE.md
# for the paper→live promotion checklist.

# ── Compose-level ─────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=hermes-live
HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent
# Live ALWAYS pins to an explicit released tag — never `latest`. The
# scripts/setup_worktree.sh helper writes a tag on every promotion;
# update this line manually after burn-in passes.
HERMES_TAG=latest
HERMES_API_PORT=8082
HERMES_DB_PORT=5434
HERMES_ENV_FILE=.env.live
HERMES_SOUL_PATH=/app/soul.md

# Per-instance host data dir
HERMES_DATA_DIR=~/.hermes-live

# Instance label — surfaced in the admin /status panel so you can tell
# paper vs live at a glance when both stacks are running.
HERMES_INSTANCE=hermes-live

# ── Application mode ──────────────────────────────────────────────────
# DO NOT change without re-reading SETUP_GUIDE.md.
HERMES_MODE=live

# ── Live order submission ─────────────────────────────────────────────
# MUST be "false" for the live stack to actually submit orders to
# Tradier. If unset or "true", the agent boots in preview-only mode and
# every C2 approval is marked FAILED with the note
# "dry_run=True — no broker order placed". Paper mode ignores this flag
# (sandbox is always safe), but live mode honors it strictly.
HERMES_DRY_RUN=false

# ── Live arming (second safety latch) ──────────────────────────────────
# Even with HERMES_DRY_RUN=false, the live stack will NOT place real orders
# unless this is explicitly "true". If unset/false the agent forces
# preview-only (dry_run) and logs a warning. This makes going live a
# deliberate, two-key action rather than a side effect of selecting "live".
HERMES_LIVE_ARMED=false

# ── Broker credentials ────────────────────────────────────────────────
# These MUST be production Tradier credentials. Anything else is a
# wasted run at best and a silent failure at worst.
#
# Resolution order in code (hermes/service1_agent/main.py:_resolve_mode_credentials):
#   1. TRADIER_LIVE_TOKEN       (mode-specific, preferred)
#   2. TRADIER_ACCESS_TOKEN     (generic fallback)
#   3. TRADIER_API_KEY          (legacy fallback — what's set below)
# Same pattern for the account: TRADIER_LIVE_ACCOUNT_ID → TRADIER_ACCOUNT_ID.
TRADIER_API_KEY=your-live-api-key-here
TRADIER_ACCOUNT_ID=your-live-account-id-here
# Override only if you're hitting a non-default Tradier endpoint.
# TRADIER_LIVE_BASE_URL=https://api.tradier.com/v1

# ── Secrets at rest ───────────────────────────────────────────────────
# Fernet key used to encrypt secrets stored via the watcher UI (LLM API
# keys, etc.) in the Hermes DB. Generate one with:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WITHOUT this set, secrets entered through the UI are written in
# cleartext and a warning is logged.
HERMES_ENCRYPTION_KEY=replace-with-fernet-key

# ── Watchlist ─────────────────────────────────────────────────────────
# Live should be a strict subset of what's been validated in paper. Add
# symbols here only after they've traded cleanly in paper for the
# burn-in window.
HERMES_WATCHLIST=AAPL,SPY,QQQ,TSLA

# ── LLM overseer (Ollama Cloud) ───────────────────────────────────────
# Same model as paper so behavior is symmetric. OLLAMA_API_KEY is
# required by the cloud endpoint.
OLLAMA_HOST=https://ollama.com/api
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# ── Optional tuning ───────────────────────────────────────────────────
# Tick loop cadence in seconds (default 300 = 5 min). Lower = faster
# reaction to mode toggles and watchlist edits, more API load.
# HERMES_TICK_INTERVAL=300

# Autonomy level. "advisory" (default) requires human C2 approval for
# every entry — recommended for live. "auto" lets the agent place
# orders without approval. Don't change this casually.
# HERMES_AI_AUTONOMY=advisory

# Admin route allowlist (comma-separated CIDRs). Default is loopback
# only; widen if you proxy the watcher externally.
# HERMES_ADMIN_ALLOW_CIDRS=127.0.0.1/32,::1/128
