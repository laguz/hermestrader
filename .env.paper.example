# ── Paper trading instance ──────────────────────────────────────────────
# Copy to `.env.paper` (gitignored) and fill in real broker credentials.
# Run with:
#   docker compose --env-file .env.paper -p hermes-paper up -d --build
#
# The watcher dashboard will be at http://localhost:8081

# Compose-level — these are read by `docker compose` itself, not the app
COMPOSE_PROJECT_NAME=hermes-paper
HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent
HERMES_TAG=latest
HERMES_API_PORT=8081
HERMES_DB_PORT=5433
HERMES_ENV_FILE=.env.paper
HERMES_SOUL_PATH=/app/soul.md

# Per-instance host data dir — keep paper and live SEPARATE on disk so a
# bad skill update in paper can never corrupt live's memory.
HERMES_DATA_DIR=~/.hermes-paper

# Application mode — flips the broker client to the paper endpoint and
# tags every order/log line so paper activity is never mistakable for live.
HERMES_MODE=paper

# ── Broker credentials ────────────────────────────────────────────────
# Use Tradier's PAPER (sandbox) keys here, NOT live keys. The platform
# will reject paper keys against the live API and vice versa, but a
# label-based safety net at the env layer is cheap and worth having.
TRADIER_API_KEY=your-paper-api-key-here
TRADIER_ACCOUNT_ID=your-paper-account-id-here

# Watchlist — paper is your sandbox, feel free to be adventurous.
HERMES_WATCHLIST=AAPL,SPY,QQQ,NVDA,AMD,KO,TSLA,META

# ── LLM overseer (Ollama Cloud) ───────────────────────────────────────
# Paper and live both point at Ollama Cloud so the overseer behaves
# identically across instances. OLLAMA_API_KEY is required by the
# cloud endpoint — fill it in your gitignored .env.paper, NOT here.
OLLAMA_HOST=https://ollama.com/api
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key-here
