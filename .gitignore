# ── Secrets and per-instance config ────────────────────────────────────
# Never commit broker credentials. The .env.*.example files are templates.
.env
.env.paper
.env.live
.env.local
.env.*.local

# ── Per-instance Hermes data dirs ──────────────────────────────────────
# When HERMES_DATA_DIR is unset the compose file falls back to
# ./.hermes-data inside the repo, which we definitely don't want tracked.
.hermes-data/
.hermes-paper/
.hermes-live/

