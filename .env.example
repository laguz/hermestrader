# Database Configuration
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes
HERMES_DSN=postgresql+psycopg://hermes:hermes@db:5432/hermes

# Bot Configuration
HERMES_WATCHLIST=AAPL,SPY,QQQ,NVDA,AMD,KO
HERMES_TICK_INTERVAL=300
HERMES_AI_AUTONOMY=advisory
HERMES_DRY_RUN=true

# Broker Credentials (Placeholder - update with your real keys)
# Single-account fallback (used when the per-mode pairs below are not set).
TRADIER_ACCESS_TOKEN=your_token_here
TRADIER_ACCOUNT_ID=your_id_here
TRADIER_BASE_URL=https://api.tradier.com/v1

# Per-mode credentials — required to use the watcher's paper/live toggle.
# When these are set, the agent reconfigures the broker on the fly when the
# operator flips the dashboard switch.
TRADIER_PAPER_TOKEN=your_sandbox_token_here
TRADIER_PAPER_ACCOUNT_ID=your_sandbox_id_here
TRADIER_PAPER_BASE_URL=https://sandbox.tradier.com/v1

TRADIER_LIVE_TOKEN=your_live_token_here
TRADIER_LIVE_ACCOUNT_ID=your_live_id_here
TRADIER_LIVE_BASE_URL=https://api.tradier.com/v1

# Initial trading mode on first ever boot. After that, the watcher's stored
# setting wins across restarts. paper|live.
HERMES_MODE=paper

# LLM Credentials (Placeholder)
LLM_API_KEY=your_key_here
