# ─── Hermes Trader — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# All values can also be set as real environment variables; .env is optional.

# ─── Database ─────────────────────────────────────────────────────────────────
HERMES_DSN=postgresql+psycopg://hermes:hermes@localhost:5432/hermes

# ─── Tradier — Paper (sandbox) ────────────────────────────────────────────────
TRADIER_PAPER_TOKEN=your_sandbox_token_here
TRADIER_PAPER_ACCOUNT_ID=your_sandbox_account_id
TRADIER_PAPER_BASE_URL=https://sandbox.tradier.com/v1

# ─── Tradier — Live ───────────────────────────────────────────────────────────
TRADIER_LIVE_TOKEN=your_live_token_here
TRADIER_LIVE_ACCOUNT_ID=your_live_account_id
TRADIER_LIVE_BASE_URL=https://api.tradier.com/v1

# ─── Agent behaviour ──────────────────────────────────────────────────────────
HERMES_TICK_INTERVAL=300          # seconds between ticks (default 300 = 5 min)
HERMES_WATCHLIST=AAPL,SPY,IWM     # comma-separated symbols (fallback if DB empty)
HERMES_DRY_RUN=true               # true = paper preview; false = live orders
HERMES_AI_AUTONOMY=advisory       # advisory | enforcing | autonomous
HERMES_ALLOW_OFFHOURS_TRADES=false # true to bypass the market-hours gate
HERMES_MAX_DAILY_LOSS=0           # daily-loss kill switch ($). 0=off. Auto-pauses
                                  # the agent when today's realized P&L <= -value.
                                  # The 'max_daily_loss' DB setting overrides this.

# ─── ML model storage ─────────────────────────────────────────────────────────
HERMES_MODEL_ROOT=~/.hermes/models # persistent volume path for XGBoost artefacts

# ─── LLM overseer ─────────────────────────────────────────────────────────────
# Provider is set at runtime via the C2 panel (/api/llm).
# These env vars seed the defaults on first boot only.
LLM_PROVIDER=mock                 # mock | local | ollama_cloud
LLM_BASE_URL=http://localhost:1234/v1  # LM Studio / Ollama local endpoint
LLM_MODEL=                        # model id (e.g. gemma-3-4b-it)
LLM_API_KEY=                      # leave blank for LM Studio / Ollama local
LLM_TEMPERATURE=0.2
LLM_VISION=true                   # enable chart-image vision prompts
LLM_TIMEOUT_S=120                 # seconds before LLM call times out

# ─── Live-tunable system_settings (set via C2 panel or direct DB write) ───────
# These are NOT env vars — they live in the system_settings table.
# Listed here for documentation purposes only.
#
#   pending_order_ttl_s   — stale PENDING order expiry (default 3600)
#   max_orders_per_tick   — safety cap on orders per tick (default 5)
#   cs75_min_dte          — CS75 entry minimum DTE (default 39)
#   cs75_max_dte          — CS75 entry maximum DTE (default 45)
#   cs7_dte               — CS7 target DTE (default 7)
#   tt45_min_dte          — TT45 entry minimum DTE (default 30)
#   tt45_max_dte          — TT45 entry maximum DTE (default 60)
#   tt45_delta            — TT45 short delta target (default 0.16)
#   cs75_max_lots         — CS75 hard lot cap per chain (default 10)
#   cs7_max_lots          — CS7 hard lot cap per chain (default 10)
#   tt45_max_lots         — TT45 hard lot cap per chain (default 5)
#   wheel_max_lots        — Wheel hard lot cap per chain (default 5)
